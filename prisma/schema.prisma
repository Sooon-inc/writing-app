generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  type      String
  hpUrl     String?
  hpContent String?
  gbpUrl    String?
  hearing   String?
  industries String?
  products      String?
  output        String?
  sitemap       String?
  hpPageOutputs String?
  hpPageThemes  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LearningMemory {
  id             String   @id
  projectId      String
  outputType     String
  instruction    String
  background     String?
  assistantReply String?
  updatesJson    String
  targetsJson    String?
  createdAt      DateTime @default(now())

  @@index([outputType, createdAt])
}
